GEMINI_API_KEY=
# 省略時は gemini-2.5-flash。別モデルを使う場合のみ指定
# GEMINI_MODEL=gemini-2.5-flash

# OpenAlex / Unpaywall（推奨）— 論文の主ソース。どちらか一方でも可（両方同じメールでOK）
# OPENALEX_MAILTO=あなたのメール@example.com
# UNPAYWALL_EMAIL=あなたのメール@example.com

# 任意: arXiv の最初の1回の前に待つミリ秒。429が続くときは 30000〜60000 など大きくする
# ARXIV_COOLDOWN_MS=30000

# 任意: すでに要約済みの論文も含め、すべて Gemini でやり直す
# FORCE_SUMMARIZE=1
