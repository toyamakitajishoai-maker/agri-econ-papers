{
  "name": "agri-econ-papers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -c 'for p in 3000 3001 3002 3003; do lsof -ti :$p | xargs kill -9 2>/dev/null || true; done; rm -rf .next && next dev -H 127.0.0.1 -p 3000'",
    "dev:clean": "npm run dev",
    "serve": "npm run build && next start -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "fetch": "tsx scripts/fetch-papers.ts",
    "summarize": "tsx scripts/summarize.ts",
    "figures": "tsx scripts/extract-figures.ts",
    "github:push": "sh scripts/github-auth-and-push.sh",
    "fetch:sample": "tsx scripts/sample-fetch.ts",
    "summarize:sample": "tsx scripts/sample-summarize.ts",
    "export:csv": "tsx scripts/export-papers-csv.ts",
    "backfill:journals": "tsx scripts/backfill-journals.ts",
    "backfill:pdf": "tsx scripts/backfill-pdf-urls.ts",
    "backfill:quiz": "tsx scripts/backfill-quiz-difficulty.ts",
    "backfill:fields": "tsx scripts/backfill-fields.ts",
    "backfill:takeaway": "tsx scripts/backfill-takeaway.ts",
    "backfill:audio": "tsx scripts/backfill-audio.ts",
    "preview:fetch": "tsx scripts/preview-fetch.ts",
    "clean:categories": "tsx scripts/clean-categories.ts",
    "build:related": "tsx scripts/build-related.ts"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "dotenv": "^16.4.5",
    "lucide-react": "^1.16.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "csv-parse": "^5.5.6",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "pdf-to-img": "^6.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
